---
import { ThemeToggle } from "./ThemeToggle.tsx";
import { AnimatedUnderline } from "./AnimatedUnderline.tsx";
import ArrowDownRight from "@assets/icons/ArrowDownRight.astro";
---

<header class="w-full flex gap-3 md:gap-4 justify-end text-sm sm:text-base">
    <!-- this and AnimatedUnderline should be Astro components, I just wanted to try React in Astro. -->
    <ThemeToggle client:load />
    <div
        class="inline-block h-auto w-px self-stretch bg-neutral-300 dark:bg-neutral-600"
    >
    </div>
    <nav>
        <ul class="flex gap-3 md:gap-4">
            <li>
                <a href="/" class="group">
                    <AnimatedUnderline client:load>home</AnimatedUnderline>
                </a>
            </li>

            <li>
                <a href="/" class="group">
                    <AnimatedUnderline client:load>
                        <div class="flex gap-1 items-center">
                            <span>resume</span>
                            <ArrowDownRight classes="w-4 h-4" />
                        </div>
                    </AnimatedUnderline>
                </a>
            </li>
        </ul>
    </nav>
</header>
