---
interface Props {
	technologies: string[];
	name: string;
}

const { technologies, name }: Props = Astro.props;
---

<h2 class="text-xs md:text-sm font-medium text-gray-600 dark:text-gray-400">
    {name}
</h2>
<div class="flex flex-wrap gap-x-3 md:gap-x-4 gap-y-1 md:gap-y-2">
    {technologies.map((technology) => <span>{technology}</span>)}
</div>
