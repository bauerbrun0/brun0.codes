---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";

import "../styles/global.css";

const { title } = Astro.props;
---

<html lang="en">
    <head>
        <Head title={title} />
    </head>
    <body class="dark:bg-[#18181A] dark:text-white">
        <div
            class="h-screen w-full md:max-w-3xl mx-auto pt-12 px-4 md:px-8 pb-36"
        >
            <Header />
            <slot />
        </div>
    </body>
</html>
