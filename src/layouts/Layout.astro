---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";

import "../styles/global.css";

const { title } = Astro.props;
---

<html lang="en">
    <head>
        <Head title={title} />
    </head>
    <body>
        <div class="dark:bg-black dark:text-white h-screen">
            <Header />
            <slot />
        </div>
    </body>
</html>
