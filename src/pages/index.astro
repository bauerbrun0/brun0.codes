---
import Layout from "@layouts/Layout.astro";
import { HeroProfile } from "@components/HeroProfile.tsx";
import Link from "@components/Link.astro";
import Technologies from "@components/Technologies.astro";
import ArrowUpRight from "@assets/icons/ArrowUpRight.astro";
import Project from "@components/Project.astro";
import Job from "@components/Job.astro";
import { EmailLink } from "@components/EmailLink.tsx";
---

<Layout title="brun0.codes">
    <HeroProfile client:load lang={Astro.currentLocale} />
    <div class="prose-sm md:prose-base text-gray-800 dark:text-gray-200 mt-10">
        <p>
            Based in <Link
                href="https://www.google.com/maps/place/P%C3%A9cs/"
                target="_blank">Pécs, Hungary</Link
            >. Recently completed a Bachelor's degree in Computer Science
            Engineering at the University of Pécs. Currently seeking a junior
            developer position.
        </p>
    </div>
    <div class="mt-8 prose-sm md:prose-base text-gray-800 dark:text-gray-200">
        <h1 class="text-sm md:text-base font-medium">Stack</h1>
        <Technologies
            name="Frontend"
            technologies={[
                "JavaScript",
                "TypeScript",
                "Svelte",
                "SvelteKit",
                "React",
                "Astro",
                "CSS",
                "TailwindCSS",
            ]}
        />
        <Technologies
            name="Backend"
            technologies={[
                "Java",
                "Spring",
                "Go",
                "SQL",
                "PostgreSQL",
                "Oracle",
            ]}
        />
        <Technologies
            name="Tools"
            technologies={["Git", "Docker", "Docker Compose", "Linux"]}
        />
    </div>
    <div
        class="mt-8 prose-sm md:prose-base text-gray-800 dark:text-gray-200 grid grid-cols-1 md:grid-cols-2 gap-8"
    >
        <div>
            <h1 class="text-sm md:text-base font-medium">Experience</h1>
            <Job
                date="2024"
                title="Intern"
                company="Seiren"
                url="https://seiren.hu"
                description="Developed a full-stack time tracking application using
                SvelteKit, TypeScript, and PostgreSQL to automate company
                workflows. Includes automated CSV data processing, Active
                Directory authentication, and role-based access control."
            />
        </div>
        <div>
            <h1 class="text-sm md:text-base font-medium">Projects</h1>
            <div class="grid grid-cols-1 gap-5">
                <Project
                    title="n2t"
                    description="Hardware simulator based on the Nand2Tetris HDL, using Go, Svelte, and PostgreSQL."
                    link="https://n2t.brun0.codes"
                    type="live"
                />
                <Project
                    title="snippetvault"
                    description="Self-hostable code snippet storage, built with Spring, Vue, and Oracle."
                    link="https://github.com/bauerbrun0/snippetvault"
                    type="github"
                />
                <Project
                    title="brun0.codes"
                    description="This website, built with Astro."
                    link="https://github.com/bauerbrun0/brun0.codes"
                    type="github"
                />
            </div>
        </div>
    </div>
    <div class="mt-8 prose-sm md:prose-base text-gray-800 dark:text-gray-200">
        <h1 class="text-sm md:text-base font-medium">Connect</h1>
        <p>
            Find me on <Link
                href="https://github.com/bauerbrun0"
                target="_blank">GitHub</Link
            >. Reach out at <EmailLink client:only />. Or download my <Link
                href="/resume"
                target="_blank">resume</Link
            >.
        </p>
    </div>
</Layout>
